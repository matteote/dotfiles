#!/bin/sh
set -eu

# Re-run when nvim's init or any plugin spec changes. Embedding source file
# hashes as comments forces chezmoi's `onchange` detector to see a new script
# body — and therefore re-trigger this script — whenever the underlying lua
# files change in the source.
#
# init.lua: {{ include (joinPath .chezmoi.sourceDir "dot_config/nvim/init.lua") | sha256sum }}
{{ range (glob (joinPath .chezmoi.sourceDir "dot_config/nvim/lua/plugins/*.lua")) -}}
# {{ . }}: {{ include . | sha256sum }}
{{ end }}
# chezmoi runs scripts in a non-login, non-interactive shell, so $HOME's
# shell rc files aren't sourced and Homebrew's bin dirs aren't on PATH.
# Load brew's shellenv ourselves so nvim (brew-installed) is discoverable.
{{ if eq .chezmoi.os "linux" -}}
[ -x /home/linuxbrew/.linuxbrew/bin/brew ] && eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
{{ else if eq .chezmoi.os "darwin" -}}
[ -x /opt/homebrew/bin/brew ] && eval "$(/opt/homebrew/bin/brew shellenv)"
{{ end }}
command -v nvim >/dev/null 2>&1 || exit 0

nvim --headless "+Lazy! sync" +qa
